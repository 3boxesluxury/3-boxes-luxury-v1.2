<!doctype html>
<html lang="{{ request.locale.iso_code }}" class="scroll-smooth">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=5">
  <meta name="theme-color" content="#0c0a09">
  
  <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
  <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  
  <title>{{ page_title }}{% unless page_title contains shop.name %} &mdash; {{ shop.name }}{% endunless %}</title>
  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}
  
  {{ content_for_header }}
  
  <!-- Google Fonts: Playfair Display for headings, Inter for body -->
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400;1,500&family=Inter:wght@300;400;500;600;700&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
  
  {{ 'theme.css' | asset_url | stylesheet_tag }}
  
  <script>
    document.documentElement.className = document.documentElement.className.replace('no-js', 'js');
    window.theme = {
      routes: {
        cart: '{{ routes.cart_url }}',
        cartAdd: '{{ routes.cart_add_url }}',
        cartChange: '{{ routes.cart_change_url }}',
        cartUpdate: '{{ routes.cart_update_url }}',
        search: '{{ routes.search_url }}',
        predictiveSearch: '{{ routes.predictive_search_url }}'
      },
      strings: {
        addToCart: {{ 'general.add_to_cart' | t | json }},
        soldOut: {{ 'general.sold_out' | t | json }},
        unavailable: {{ 'general.unavailable' | t | json }},
        cartEmpty: {{ 'general.cart_empty' | t | json }}
      },
      moneyFormat: {{ shop.money_format | json }},
      cartCount: {{ cart.item_count | json }}
    };
  </script>
  
  {% style %}
    :root {
      --color-bg: #0c0a09;
      --color-bg-secondary: #1c1917;
      --color-bg-tertiary: #292524;
      --color-bg-card: #1c1917cc;
      --color-text: #fef3c7;
      --color-text-secondary: #fde68a99;
      --color-text-muted: #a8a29e;
      --color-gold: #d4a437;
      --color-gold-light: #f5e6a3;
      --color-gold-dark: #b8860b;
      --color-amber-600: #d97706;
      --color-amber-500: #f59e0b;
      --color-amber-400: #fbbf24;
      --color-amber-300: #fcd34d;
      --color-amber-200: #fde68a;
      --color-amber-100: #fef3c7;
      --color-border: rgba(120, 53, 15, 0.3);
      --color-border-light: rgba(120, 53, 15, 0.2);
      --color-border-hover: rgba(217, 119, 6, 0.4);
      --font-heading: 'Playfair Display', 'Cormorant Garamond', Georgia, serif;
      --font-body: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      --font-accent: 'Cormorant Garamond', 'Playfair Display', Georgia, serif;
    }
  {% endstyle %}
</head>

<body class="bg-[#0c0a09] text-[#fef3c7] antialiased min-h-screen flex flex-col font-body">
  
  {% section 'announcement-bar' %}
  {% section 'header' %}
  
  <main id="main-content" class="flex-1" role="main">
    {{ content_for_layout }}
  </main>
  
  {% section 'footer' %}
  
  <!-- Cart Drawer -->
  <div id="cart-drawer" class="cart-drawer" aria-hidden="true">
    <div class="cart-drawer-overlay" data-cart-close></div>
    <div class="cart-drawer-inner">
      <div class="cart-drawer-header">
        <h2 class="text-xl font-semibold text-amber-100">Shopping Cart</h2>
        <button data-cart-close class="text-amber-200/60 hover:text-amber-400 transition-colors">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
        </button>
      </div>
      <div class="cart-drawer-body" id="cart-drawer-items">
        <!-- Cart items loaded dynamically -->
      </div>
      <div class="cart-drawer-footer" id="cart-drawer-footer">
        <!-- Cart footer with total and checkout -->
      </div>
    </div>
  </div>
  
  <!-- Mobile Navigation Drawer -->
  <div id="mobile-nav" class="mobile-nav" aria-hidden="true">
    <div class="mobile-nav-overlay" data-nav-close></div>
    <div class="mobile-nav-inner">
      <div class="mobile-nav-header">
        <span class="gold-shimmer text-xl font-semibold tracking-widest">3 BOXES</span>
        <button data-nav-close class="text-amber-200/60 hover:text-amber-400 transition-colors">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
        </button>
      </div>
      <nav class="mobile-nav-links">
        {% for link in linklists.main-menu.links %}
          <a href="{{ link.url }}" class="mobile-nav-link{% if link.active %} active{% endif %}">{{ link.title }}</a>
          {% if link.links.size > 0 %}
            <div class="mobile-nav-sublinks">
              {% for child in link.links %}
                <a href="{{ child.url }}" class="mobile-nav-sublink">{{ child.title }}</a>
              {% endfor %}
            </div>
          {% endif %}
        {% endfor %}
      </nav>
      <div class="mobile-nav-footer">
        {% if shop.customer_accounts_enabled %}
          {% if customer %}
            <a href="{{ routes.account_url }}" class="btn btn-outline w-full mb-2">My Account</a>
          {% else %}
            <a href="{{ routes.account_login_url }}" class="btn btn-outline w-full mb-2">Sign In</a>
            <a href="{{ routes.account_register_url }}" class="btn btn-primary w-full">Create Account</a>
          {% endif %}
        {% endif %}
      </div>
    </div>
  </div>
  
  {{ 'theme.js' | asset_url | script_tag }}
</body>
</html>
