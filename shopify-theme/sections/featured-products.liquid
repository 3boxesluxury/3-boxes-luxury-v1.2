{%- comment -%}
  Featured Products Section
  Displays a curated grid of products from a selected collection.
{%- endcomment -%}

{%- liquid
  assign heading = section.settings.heading
  assign description = section.settings.description
  assign collection = collections[section.settings.collection]
  assign products_per_row = section.settings.products_per_row | default: 4
  assign rows = section.settings.rows | default: 1
  assign total_products = products_per_row | times: rows

  case products_per_row
    when 2
      assign grid_classes = 'grid-cols-1 sm:grid-cols-2'
    when 3
      assign grid_classes = 'grid-cols-1 sm:grid-cols-2 md:grid-cols-3'
    when 4
      assign grid_classes = 'grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4'
    else
      assign grid_classes = 'grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4'
  endcase
-%}

<section
  id="featured-products-{{ section.id }}"
  class="relative py-16 md:py-24"
  style="background-color: {{ section.settings.background_color | default: '#0c0a09' }};"
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    {%- comment -%} Section Header {%- endcomment -%}
    {%- if heading != blank or description != blank -%}
      <div class="mb-12 text-center">
        {%- if heading != blank -%}
          <h2 class="font-heading text-3xl font-bold tracking-tight text-foreground sm:text-4xl lg:text-5xl" style="font-family: 'Playfair Display', serif;">
            {{ heading }}
          </h2>
        {%- endif -%}
        {%- if description != blank -%}
          <p class="mx-auto mt-4 max-w-2xl text-base text-muted-foreground sm:text-lg">
            {{ description }}
          </p>
        {%- endif -%}
        {%- comment -%} Decorative divider {%- endcomment -%}
        <div class="mx-auto mt-6 flex items-center justify-center gap-3">
          <span class="h-px w-12 bg-gradient-to-r from-transparent to-gold/50"></span>
          <span class="text-gold">&#9830;</span>
          <span class="h-px w-12 bg-gradient-to-l from-transparent to-gold/50"></span>
        </div>
      </div>
    {%- endif -%}

    {%- comment -%} Product Grid {%- endcomment -%}
    {%- if collection and collection.products.size > 0 -%}
      <div class="product-grid grid {{ grid_classes }} gap-4 md:gap-6">
        {%- for product in collection.products limit: total_products -%}
          {%- render 'product-card', product: product -%}
        {%- endfor -%}
      </div>
    {%- else -%}
      {%- comment -%} Empty state / Placeholder {%- endcomment -%}
      <div class="product-grid grid {{ grid_classes }} gap-4 md:gap-6">
        {%- for i in (1..total_products) -%}
          <div class="flex flex-col overflow-hidden rounded-lg border border-border/40 bg-card">
            <div class="aspect-square bg-stone-900/50 flex items-center justify-center">
              <svg class="h-12 w-12 text-stone-700" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5m8.25 3v6.75m0 0l-3-3m3 3l3-3M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" /></svg>
            </div>
            <div class="p-4 space-y-3">
              <div class="h-3 w-20 rounded bg-stone-800"></div>
              <div class="h-4 w-3/4 rounded bg-stone-800"></div>
              <div class="h-4 w-1/3 rounded bg-stone-800"></div>
            </div>
          </div>
        {%- endfor -%}
      </div>
      {%- if section.settings.collection == blank -%}
        <p class="mt-8 text-center text-sm text-muted-foreground">
          Select a collection in the section settings to display products.
        </p>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Featured Products",
  "tag": "section",
  "class": "featured-products",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Curated Selection"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Discover our handpicked luxury gifts, each one a statement of elegance and refinement.</p>"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_per_row",
      "label": "Products per row",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "rows",
      "label": "Rows to show",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 1
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#0c0a09"
    }
  ],
  "presets": [
    {
      "name": "Featured Products"
    }
  ]
}
{% endschema %}
