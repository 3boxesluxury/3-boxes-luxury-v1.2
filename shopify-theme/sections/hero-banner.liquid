{%- comment -%}
  Hero Banner Section — 3 BOXES LUXURY
  Full-viewport hero with decorative particles, bokeh lights, golden rays,
  and configurable content (subtitle, title, description, CTA buttons).
{%- endcomment -%}

<section
  id="hero-{{ section.id }}"
  class="hero"
  data-section-id="{{ section.id }}"
  data-section-type="hero-banner"
  role="banner"
  aria-label="{{ section.settings.title | escape }}"
>
  {%- comment -%} Background Image {%- endcomment -%}
  <div class="hero-bg">
    {%- if section.settings.hero_image != blank -%}
      <img
        src="{{ section.settings.hero_image | image_url: width: 1920 }}"
        alt="{{ section.settings.hero_image.alt | default: section.settings.title | escape }}"
        width="1920"
        height="1080"
        loading="{% if section.index == 0 %}eager{% else %}lazy{% endif %}"
        fetchpriority="{% if section.index == 0 %}high{% else %}low{% endif %}"
      >
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
    {%- endif -%}
  </div>

  {%- comment -%} Overlay Gradients {%- endcomment -%}
  <div
    class="hero-overlay"
    style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"
  ></div>
  <div class="hero-overlay-bottom"></div>

  {%- comment -%} Decorative: Golden Particles (10) {%- endcomment -%}
  <div class="hero-particles" aria-hidden="true">
    {%- for i in (1..10) -%}
      <span
        class="golden-particle"
        style="
          width: {{ 3 | plus: forloop.index | modulo: 6 | plus: 2 }}px;
          height: {{ 3 | plus: forloop.index | modulo: 6 | plus: 2 }}px;
          left: {{ forloop.index | times: 9 | modulo: 95 }}%;
          animation-duration: {{ 8 | plus: forloop.index | modulo: 7 | plus: 6 }}s;
          animation-delay: {{ forloop.index | times: 0.7 }}s;
        "
      ></span>
    {%- endfor -%}
  </div>

  {%- comment -%} Decorative: Bokeh Lights (6) {%- endcomment -%}
  <div class="hero-particles" aria-hidden="true">
    {%- for i in (1..6) -%}
      <span
        class="bokeh-light"
        style="
          width: {{ 60 | plus: forloop.index | times: 20 }}px;
          height: {{ 60 | plus: forloop.index | times: 20 }}px;
          left: {{ forloop.index | times: 15 | modulo: 80 | plus: 5 }}%;
          top: {{ forloop.index | times: 12 | modulo: 60 | plus: 10 }}%;
          animation-duration: {{ 6 | plus: forloop.index | modulo: 5 | plus: 5 }}s;
          animation-delay: {{ forloop.index | times: 1.1 }}s;
        "
      ></span>
    {%- endfor -%}
  </div>

  {%- comment -%} Decorative: Golden Rays (5) {%- endcomment -%}
  <div class="hero-particles" aria-hidden="true">
    {%- for i in (1..5) -%}
      <span
        class="golden-ray"
        style="
          left: {{ forloop.index | times: 18 | modulo: 80 | plus: 10 }}%;
          animation-delay: {{ forloop.index | times: 0.8 }}s;
        "
      ></span>
    {%- endfor -%}
  </div>

  {%- comment -%} Hero Content {%- endcomment -%}
  <div class="hero-content">
    {%- comment -%} Logo Icon {%- endcomment -%}
    {%- if section.settings.logo_icon != blank -%}
      <img
        class="hero-logo-icon"
        src="{{ section.settings.logo_icon | image_url: width: 200 }}"
        alt="{{ shop.name | escape }}"
        width="100"
        height="100"
        loading="eager"
      >
    {%- else -%}
      <div class="hero-logo-icon" aria-hidden="true">
        <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg" width="100" height="100">
          <rect x="10" y="30" width="24" height="50" rx="2" stroke="#d4a437" stroke-width="2" fill="rgba(212,164,55,0.1)"/>
          <rect x="38" y="20" width="24" height="60" rx="2" stroke="#d4a437" stroke-width="2" fill="rgba(212,164,55,0.15)"/>
          <rect x="66" y="35" width="24" height="45" rx="2" stroke="#d4a437" stroke-width="2" fill="rgba(212,164,55,0.1)"/>
          <line x1="22" y1="25" x2="22" y2="30" stroke="#d4a437" stroke-width="1.5"/>
          <line x1="50" y1="14" x2="50" y2="20" stroke="#d4a437" stroke-width="1.5"/>
          <line x1="78" y1="30" x2="78" y2="35" stroke="#d4a437" stroke-width="1.5"/>
          <circle cx="22" cy="22" r="3" fill="#d4a437" opacity="0.6"/>
          <circle cx="50" cy="11" r="4" fill="#d4a437" opacity="0.8"/>
          <circle cx="78" cy="27" r="3" fill="#d4a437" opacity="0.6"/>
        </svg>
      </div>
    {%- endif -%}

    {%- comment -%} Subtitle {%- endcomment -%}
    {%- if section.settings.subtitle != blank -%}
      <p class="hero-subtitle fade-in stagger-1">{{ section.settings.subtitle }}</p>
    {%- endif -%}

    {%- comment -%} Title {%- endcomment -%}
    {%- if section.settings.title != blank -%}
      <h1 class="hero-title gold-shimmer fade-in stagger-2">{{ section.settings.title }}</h1>
    {%- endif -%}

    {%- comment -%} Description {%- endcomment -%}
    {%- if section.settings.description != blank -%}
      <p class="hero-description fade-in stagger-3">{{ section.settings.description }}</p>
    {%- endif -%}

    {%- comment -%} CTA Buttons (up to 3) {%- endcomment -%}
    {%- if section.blocks.size > 0 -%}
      <div class="hero-buttons fade-in stagger-4">
        {%- for block in section.blocks -%}
          {%- if block.settings.button_text != blank -%}
            <a
              href="{{ block.settings.button_url }}"
              class="btn {{ block.settings.button_style }} btn-lg"
              {{ block.shopify_attributes }}
            >
              {%- if block.settings.button_icon != blank -%}
                <span aria-hidden="true">{{ block.settings.button_icon }}</span>
              {%- endif -%}
              {{- block.settings.button_text -}}
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "hero-banner-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero background image",
      "info": "Recommended: 1920x1080px or larger"
    },
    {
      "type": "image_picker",
      "id": "logo_icon",
      "label": "Logo icon",
      "info": "Decorative logo above the title. 200x200px recommended."
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "CURATED LUXURY"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "3 BOXES LUXURY"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Discover an exquisite collection of hand-curated luxury gifts. From timeless jewelry to premium watches, every piece tells a story of elegance and sophistication."
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity (%)",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 85,
      "info": "Controls the darkness of the overlay on the hero image"
    }
  ],
  "blocks": [
    {
      "type": "button",
      "name": "CTA Button",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "button_text",
          "label": "Button text",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "button_url",
          "label": "Button URL"
        },
        {
          "type": "select",
          "id": "button_style",
          "label": "Button style",
          "options": [
            { "value": "btn-primary", "label": "Primary (Gold)" },
            { "value": "btn-outline", "label": "Outline" },
            { "value": "btn-secondary", "label": "Secondary (Dark)" }
          ],
          "default": "btn-primary"
        },
        {
          "type": "text",
          "id": "button_icon",
          "label": "Button icon (emoji/symbol)",
          "info": "Optional. e.g. ✦ →"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "category": "Hero",
      "settings": {
        "subtitle": "CURATED LUXURY",
        "title": "3 BOXES LUXURY",
        "description": "Discover an exquisite collection of hand-curated luxury gifts. From timeless jewelry to premium watches, every piece tells a story of elegance and sophistication.",
        "overlay_opacity": 85
      },
      "blocks": [
        {
          "type": "button",
          "settings": {
            "button_text": "Shop Now",
            "button_style": "btn-primary",
            "button_icon": "✦"
          }
        },
        {
          "type": "button",
          "settings": {
            "button_text": "Explore Collections",
            "button_style": "btn-outline"
          }
        },
        {
          "type": "button",
          "settings": {
            "button_text": "Gift Guide",
            "button_style": "btn-secondary"
          }
        }
      ]
    }
  ]
}
{% endschema %}
