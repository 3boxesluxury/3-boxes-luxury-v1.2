<!-- Search Results Section -->
<div class="container-luxury section-spacing">
  {%- if search.performed -%}
    <div class="text-center mb-12">
      <h1 class="section-heading" style="font-size:2rem">
        {%- if search.results_count > 0 -%}
          {{ search.results_count }} result{{ search.results_count | pluralize: '', 's' }} for "{{ search.terms | escape }}"
        {%- else -%}
          No results for "{{ search.terms | escape }}"
        {%- endif -%}
      </h1>
    </div>

    {%- if search.results_count > 0 -%}
      {%- paginate search.results by 24 -%}
        <div class="product-grid">
          {%- for item in search.results -%}
            {%- if item.object_type == 'product' -%}
              {%- render 'product-card', product: item, show_badges: true -%}
            {%- elsif item.object_type == 'article' -%}
              <div class="card-luxury overflow-hidden">
                <div class="p-6">
                  <p class="text-xs uppercase tracking-wider" style="color:#d97706;margin-bottom:0.5rem">Blog Post</p>
                  <h3 style="font-size:1rem;font-weight:600;color:#fef3c7;margin-bottom:0.5rem">
                    <a href="{{ item.url }}" style="color:inherit">{{ item.title }}</a>
                  </h3>
                  {%- if item.excerpt -%}
                    <p style="font-size:0.875rem;color:#a8a29e;line-height:1.6">{{ item.excerpt | strip_html | truncatewords: 30 }}</p>
                  {%- endif -%}
                  <a href="{{ item.url }}" style="font-size:0.8125rem;color:#fbbf24;margin-top:0.75rem;display:inline-block">Read more →</a>
                </div>
              </div>
            {%- elsif item.object_type == 'page' -%}
              <div class="card-luxury overflow-hidden">
                <div class="p-6">
                  <p class="text-xs uppercase tracking-wider" style="color:#d97706;margin-bottom:0.5rem">Page</p>
                  <h3 style="font-size:1rem;font-weight:600;color:#fef3c7;margin-bottom:0.5rem">
                    <a href="{{ item.url }}" style="color:inherit">{{ item.title }}</a>
                  </h3>
                  <p style="font-size:0.875rem;color:#a8a29e;line-height:1.6">{{ item.content | strip_html | truncatewords: 30 }}</p>
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          <div class="pagination" style="margin-top:3rem">
            {%- if paginate.previous -%}
              <a href="{{ paginate.previous.url }}" class="pagination-btn">←</a>
            {%- else -%}
              <span class="pagination-btn disabled">←</span>
            {%- endif -%}

            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}
                <a href="{{ part.url }}" class="pagination-btn">{{ part.title }}</a>
              {%- else -%}
                {%- if part.title == paginate.current_page -%}
                  <span class="pagination-btn active">{{ part.title }}</span>
                {%- else -%}
                  <span class="pagination-btn disabled">{{ part.title }}</span>
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}

            {%- if paginate.next -%}
              <a href="{{ paginate.next.url }}" class="pagination-btn">→</a>
            {%- else -%}
              <span class="pagination-btn disabled">→</span>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endpaginate -%}
    {%- else -%}
      <div class="text-center" style="padding:4rem 0">
        <p style="font-size:3rem;margin-bottom:1rem">🔍</p>
        <p style="color:#a8a29e;margin-bottom:2rem">Try searching for something else</p>
        <form action="{{ routes.search_url }}" method="get" role="search" class="search-form">
          <svg class="search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search luxury gifts..." autocomplete="off">
          <input type="hidden" name="type" value="product,article,page">
        </form>
      </div>
    {%- endif -%}
  {%- else -%}
    <div class="text-center" style="padding:4rem 0">
      <h1 class="section-heading" style="font-size:2rem">Search</h1>
      <form action="{{ routes.search_url }}" method="get" role="search" class="search-form">
        <svg class="search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <input type="search" name="q" placeholder="Search luxury gifts..." autocomplete="off">
        <input type="hidden" name="type" value="product,article,page">
      </form>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Search Results",
  "settings": []
}
{% endschema %}
